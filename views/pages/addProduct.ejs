<!DOCTYPE html>
<html>
    <head>
        <title>Add Product</title>
    </head>
    <body>
        <h1>Add a Product</h1>
        <form action="/add-product" method="post">
            <input type="text" name="title" placeholder="Enter title of your product" required>
            <br><br>
            <input type="text" name="description" placeholder="description of your product" required>
            <br><br>
            <input type="number" name="price" placeholder="price" required>
            <br><br>
            <input type="text" name="image" placeholder="image Url" required>
            <br><br>
            <button type="submit">Add Product</button>
        </form>
    </body>
</html>