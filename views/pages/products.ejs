<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include("../partials/navbar") %>
<form action="/products" method="GET" style="margin:1.5rem"class="mb-4">

    <div class="input-group">

        <input
            type="text"
            name="search"
            class="form-control"
            placeholder="Search products..."
        >

        <button class="btn btn-dark">
            Search
        </button>

    </div>

</form>

<div class="container my-5">
    <h1 class="mb-4 text-center">All Products</h1>

    <div class="row g-4">
        <% products.forEach(product => { %>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="<%= product.image %>" class="card-img-top" style="height:220px; object-fit:cover;">

                    <div class="card-body">
                        <h5 class="card-title"><%= product.title %></h5>
                        <p class="card-text"><%= product.description %></p>
                        <h6 class="fw-bold">Rs <%= product.price %></h6>

                        <a href="/products/<%= product._id %>" class="btn btn-primary w-100">
                            View Details
                        </a>
                        <% if(product.user.isAdmin){ %>
                        <form action="/delete-product/<%= product._id %>" method="post">
                            <button class="btn btn-danger w-100 mt-2">
                                Delete Product
                            </button>
                        </form>
                        <a href="/edit-product/<%= product._id %>" class="btn btn-warning w-100 mt-2">Edit Product</a>
                        <% }%>
                    </div>
                </div>
            </div>

        <% }) %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>